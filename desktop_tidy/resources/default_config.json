{
  "schema_version": 2,
  "desktop": {
    "path": "",
    "takeover_enabled": false,
    "restore_required": false,
    "explorer_icons_hidden": false,
    "startup_enabled": false,
    "primary_screen_id": "primary"
  },
  "appearance_defaults": {
    "background_color": "#111111",
    "background_opacity": 0.6
  },
  "panel_groups": [
    {
      "id": "group-default",
      "screen_id": "primary",
      "geometry": {
        "rx": 0.04,
        "ry": 0.04,
        "rw": 0.72,
        "rh": 0.62
      },
      "tab_ids": [
        "tab-folders",
        "tab-documents",
        "tab-images",
        "tab-archives",
        "tab-apps",
        "tab-other"
      ],
      "active_tab_id": "tab-folders",
      "appearance": {
        "background_color": "#111111",
        "background_opacity": 0.6
      },
      "locked": false,
      "collapsed": false
    }
  ],
  "panel_tabs": [
    {"id": "tab-folders", "group_id": "group-default", "name": "文件夹", "order": 0, "category_role": "folders"},
    {"id": "tab-documents", "group_id": "group-default", "name": "文档", "order": 1, "category_role": "documents"},
    {"id": "tab-images", "group_id": "group-default", "name": "图片", "order": 2, "category_role": "images"},
    {"id": "tab-archives", "group_id": "group-default", "name": "压缩包", "order": 3, "category_role": "archives"},
    {"id": "tab-apps", "group_id": "group-default", "name": "应用", "order": 4, "category_role": "apps"},
    {"id": "tab-other", "group_id": "group-default", "name": "其它", "order": 5, "category_role": "other"}
  ],
  "rules": [
    {"id": "rule-folders", "name": "文件夹", "matcher_kind": "folder", "target_tab_id": "tab-folders", "extensions": [], "enabled": true, "order": 0},
    {"id": "rule-documents", "name": "文档", "matcher_kind": "extension", "target_tab_id": "tab-documents", "extensions": [".pdf", ".doc", ".docx", ".rtf", ".odt", ".wps", ".xls", ".xlsx", ".xlsm", ".csv", ".ods", ".ppt", ".pptx", ".pptm", ".pps", ".ppsx", ".txt", ".md"], "enabled": true, "order": 10},
    {"id": "rule-images", "name": "图片", "matcher_kind": "extension", "target_tab_id": "tab-images", "extensions": [".png", ".jpg", ".jpeg", ".gif", ".webp", ".bmp", ".tif", ".tiff", ".svg"], "enabled": true, "order": 20},
    {"id": "rule-archives", "name": "压缩包", "matcher_kind": "extension", "target_tab_id": "tab-archives", "extensions": [".zip", ".rar", ".7z", ".tar", ".gz", ".xz", ".bz2", ".iso"], "enabled": true, "order": 30},
    {"id": "rule-apps", "name": "应用", "matcher_kind": "extension", "target_tab_id": "tab-apps", "extensions": [".lnk", ".url", ".exe", ".msi"], "enabled": true, "order": 40},
    {"id": "rule-other", "name": "其它", "matcher_kind": "fallback", "target_tab_id": "tab-other", "extensions": [], "enabled": true, "order": 1000}
  ],
  "manual_overrides": [],
  "external_refs": []
}
